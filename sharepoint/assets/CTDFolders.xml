<?xml version="1.0" encoding="utf-8"?>
<!--
DUMMY DATA FOR VISUALIZATION - CTD Folder Hierarchy:

CTD FOLDER 1: Module 1 - Administrative Information
- Title: Module 1 - Administrative Information
- FolderId: M1
- ParentFolderId: (null - root level)
- IsFolder: True
- SortOrder: 1
- Description: Contains administrative and regulatory information
- EctdSection: 1.0 (lookup to eCTDSections list)

CTD FOLDER 2: Module 1.1 - Forms and Coversheets
- Title: Module 1.1 - Forms and Coversheets
- FolderId: M1.1
- ParentFolderId: M1
- IsFolder: True
- SortOrder: 2
- Description: Application forms and coversheets
- EctdSection: 1.1 (lookup to eCTDSections list)

CTD FOLDER 3: Module 1.2 - Cover Letters
- Title: Module 1.2 - Cover Letters
- FolderId: M1.2
- ParentFolderId: M1
- IsFolder: True
- SortOrder: 3
- Description: Regulatory cover letters and correspondence
- EctdSection: 1.2 (lookup to eCTDSections list)

CTD FOLDER 4: Module 2 - Quality Summary
- Title: Module 2 - Quality Summary
- FolderId: M2
- ParentFolderId: (null - root level)
- IsFolder: True
- SortOrder: 4
- Description: Quality overall summary and introduction
- EctdSection: 2.0 (lookup to eCTDSections list)

CTD FOLDER 5: Module 3 - Quality
- Title: Module 3 - Quality
- FolderId: M3
- ParentFolderId: (null - root level)
- IsFolder: True
- SortOrder: 5
- Description: Detailed quality information and data
- EctdSection: 3.0 (lookup to eCTDSections list)

HIERARCHY:
Module 1 (M1)
├── Module 1.1 (M1.1)
├── Module 1.2 (M1.2)
Module 2 (M2)
Module 3 (M3)

CONNECTIONS:
CTDFolders → eCTDSections (via EctdSection lookup)
Templates → CTDFolders (via MappedCTDFolder lookup)
Documents → CTDFolders (via CTDFolder lookup)
-->
<List xmlns:ows="Microsoft SharePoint" Title="CTD Folders" Direction="$Resources:Direction;" Url="Lists/CTDFolders" BaseType="0" xmlns="http://schemas.microsoft.com/sharepoint/">
  <MetaData>
    <ContentTypes>
      <ContentTypeRef ID="0x01">
        <Folder />
      </ContentTypeRef>
      <ContentTypeRef ID="0x0120" />
    </ContentTypes>
    <Fields>
      <Field ID="{B4B3C9A0-4E9A-4B8A-8B8A-8B8A8B8A8B8A}" Type="Text" Name="FolderId" DisplayName="Folder Id" />
      <Field ID="{C4B3C9A0-4E9A-4B8A-8B8A-8B8A8B8A8B8A}" Type="Text" Name="ParentFolderId" DisplayName="Parent Folder Id" />
      <Field ID="{D4B3C9A0-4E9A-4B8A-8B8A-8B8A8B8A8B8A}" Type="Boolean" Name="IsFolder" DisplayName="Is Folder" />
      <Field ID="{E4B3C9A0-4E9A-4B8A-8B8A-8B8A8B8A8B8A}" Type="Number" Name="SortOrder" DisplayName="Sort Order" Decimals="0" />
      <Field ID="{F4B3C9A0-4E9A-4B8A-8B8A-8B8A8B8A8B8A}" Type="Note" Name="Description" DisplayName="Description" NumLines="6" />

      <!-- Optional mapping: link CTD folder node to an eCTD section master record -->
      <Field ID="{A4B3C9A0-4E9A-4B8A-8B8A-8B8A8B8A8B8A}" Type="Lookup" Name="EctdSection" DisplayName="eCTD Section" List="Lists/eCTDSections" ShowField="SectionCode" />
    </Fields>
    <Views>
      <View BaseViewID="1" Type="HTML" WebPartZoneID="Main" DisplayName="$Resources:core,AllItems;" DefaultView="TRUE" MobileView="TRUE" MobileDefaultView="TRUE" SetupPath="pages\viewpage.aspx" ImageUrl="/_layouts/images/generic.png" Url="AllItems.aspx">
        <XslLink Default="TRUE">main.xsl</XslLink>
        <RowLimit Paged="TRUE">30</RowLimit>
        <Toolbar Type="Standard" />
        <ViewFields>
          <FieldRef Name="LinkTitle"></FieldRef>
          <FieldRef Name="FolderId"></FieldRef>
          <FieldRef Name="ParentFolderId"></FieldRef>
          <FieldRef Name="IsFolder"></FieldRef>
          <FieldRef Name="SortOrder"></FieldRef>
          <FieldRef Name="EctdSection"></FieldRef>
          <FieldRef Name="Description"></FieldRef>
        </ViewFields>
        <Query>
          <OrderBy>
            <FieldRef Name="ID" />
          </OrderBy>
        </Query>
      </View>
    </Views>
    <Forms>
      <Form Type="DisplayForm" Url="DispForm.aspx" SetupPath="pages\form.aspx" WebPartZoneID="Main" />
      <Form Type="EditForm" Url="EditForm.aspx" SetupPath="pages\form.aspx" WebPartZoneID="Main" />
      <Form Type="NewForm" Url="NewForm.aspx" SetupPath="pages\form.aspx" WebPartZoneID="Main" />
    </Forms>
  </MetaData>
</List>